# Copy to .env and fill in.

# Anthropic API key — required for AI analysis & sidebar
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Database — sqlite for dev, postgres for prod
DATABASE_URL=sqlite:///./helix.db
# DATABASE_URL=postgresql+psycopg2://helix:helix@localhost:5432/helix

# Redis — leave blank to disable caching
REDIS_URL=redis://localhost:6379/0

# Market data provider (yfinance is free; swap in Polygon/Alpaca for prod)
MARKET_DATA_PROVIDER=yfinance
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# CORS — comma-separated origins. Use * for dev.
ALLOWED_ORIGINS=*

# File storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Auth
JWT_SECRET=change-me-in-production
JWT_ALG=HS256
JWT_EXPIRE_MIN=60
